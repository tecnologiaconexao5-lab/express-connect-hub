# ============================================================
# SUPABASE (Obrigatório)
# ============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ============================================================
# MAPBOX (Obrigatório para cálculo de distância)
# Obtenha em: https://account.mapbox.com/access-tokens
# ============================================================
VITE_MAPBOX_ACCESS_TOKEN=pk.your.Mapbox.public.token.here
VITE_MAPBOX_TOKEN=pk.your.Mapbox.public.token.here

# ============================================================
# EVOLUTION API (WhatsApp)
# Docker padrão: porta 8080
# ============================================================
VITE_EVOLUTION_API_URL=http://127.0.0.1:8080
VITE_EVOLUTION_API_KEY=your-evolution-api-key
VITE_EVOLUTION_INSTANCE_NAME=recrutamento-conexao-express
VITE_EVOLUTION_SERVER_URL=http://127.0.0.1:8080
VITE_EVOLUTION_INSTANCE=recrutamento-conexao-express

# ============================================================
# N8N (Automação)
# Porta padrão: 5678
# ============================================================
VITE_N8N_API_URL=http://localhost:5678
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook/recrutamento-whatsapp
VITE_N8N_WEBHOOK_WHATSAPP_RECRUTAMENTO=http://localhost:5678/webhook/recrutamento-whatsapp
VITE_N8N_WEBHOOK_ZOHO_EMAIL=http://localhost:5678/webhook/zoho-email
VITE_N8N_WEBHOOK_COMERCIAL_AUTOMACAO=http://localhost:5678/webhook/comercial-automacao
VITE_N8N_WEBHOOK_OS=http://localhost:5678/webhook/os-whatsapp
VITE_N8N_WEBHOOK_OS_WHATSAPP_URL=http://localhost:5678/webhook/os-whatsapp

# ============================================================
# IA - GROQ (Principal)
# Obtenha em: https://console.groq.com
# ============================================================
VITE_GROQ_API_KEY=gsk_your-groq-api-key-here
VITE_AI_PROVIDER=groq

# ============================================================
# IA - GEMINI (Alternativa)
# Obtenha em: https://aistudio.google.com/app/apikey
# ============================================================
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# IA - OPENROUTER (Alternativa Multi-Modelo)
# ============================================================
VITE_OPENROUTER_API_KEY=your-openrouter-api-key-here

# ============================================================
# IA - OPENAI (Fallback Premium)
# ============================================================
VITE_OPENAI_API_KEY=your-openai-api-key-here
# ============================================================
# SEGURANÇA (Admin)
# ============================================================
VITE_ADMIN_DELETE_PASSWORD=your-secure-delete-password

# ============================================================
# ZOHO EMAIL (via N8N)
# ============================================================
ZOHO_CLIENT_SECRET=your-zoho-client-secret

# ============================================================
# OBS: Chaves privadas (GROQ_API_KEY, GEMINI_API_KEY, EVOLUTION_API_KEY)
# NÃO devem ser expostas no código. Use .env e N8N para gerenciar.
# ============================================================
