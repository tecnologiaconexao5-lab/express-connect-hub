        [
          {
            "node": "Verifica Canal",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Verifica Canal": {
      "main": [
        [
          {
            "node": "Evolution API Send Text",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Evolution API Send Text": {
      "main": [
        [
          {
            "node": "Supabase Update Success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
